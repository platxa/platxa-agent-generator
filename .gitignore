# Claude Code session files (not the skill code)
.claude/research.json
.claude/session_state.json
**/.claude/debug_sessions.json
.claude/PROGRESS.md
.claude/feature_list.json
.claude/generated_features.json
.claude/integration_metrics.json
.claude/skill_state.json
.claude/settings.local.json
.claude/SPEC_PROGRESS.md
.claude/plans/
.claude/checkpoints/
.claude/state/
**/.claude/state/
.claude/config/
.claude/intent_state/
.claude/backups/
.claude/findings/
.claude/history/
.claude/*.backup*
# Sprint/milestone backup snapshots use a `-backup-<timestamp>` infix
# (e.g. ``spec.md.sprint-plugin-restructure-backup-20260422_034714``)
# which the dot-anchored ``*.backup*`` above does NOT match.
.claude/*-backup-*
.claude/**/*-backup-*
# Scheduler lockfile — volatile runtime state, never tracked
.claude/scheduled_tasks.lock
.claude/**/.ruff_cache/
.claude/**/__pycache__/
.claude/**/.pytest_cache/
.claude/**/.benchmarks/

# platxa-code-agent spec-workflow harness state (regenerated per run)
.claude/.last_milestone
.claude/CHANGELOG.md
.claude/claude-progress.txt
.claude/feature_list.json.lock
.claude/feature_list_snapshots/
.claude/hook_context_chars.jsonl
.claude/observations.jsonl
.claude/pre_compact_state.json
.claude/review-output.md
.claude/review-output-f*.md
.claude/reviewer-summary.txt
# Nested .claude/ dirs created when hooks run inside a subdirectory —
# these are duplicates of root .claude/ state and should never be tracked
**/.claude/observations.jsonl
.claude/skills/**/.claude/

# platxa-memory plugin session markers and runtime state
.claude/.memory-synthesized-*
.claude/.observer-advisory-state.json

# Subagent dispatch correlation logs
.claude/dispatches.jsonl
.claude/dispatches_index.json
.claude/dispatches_index.json.lock
.claude/dispatch_index/

# Agent definitions (generated per-developer, not tracked)
.claude/agents/

# Agent transcripts, memory, instincts, telemetry (per-developer)
.claude/agent_transcripts/
.claude/agent-memory/
.claude/instincts/
.claude/telemetry/
.claude/rules/

# Historical backup snapshots
.claude/generated_features.unsorted.bak.json
.claude/generated_features.v1.bak.json

# Hatch
.hatch/

# MCP configuration (user-specific paths)
.mcp.json
# Debug session state files
**/.claude/debug_sessions.json

# MAO state and checkpoints
mao_state.db
checkpoints/

# Spec workflow artifacts (local-only; historical backups and living spec)
.claude/feature_list.json.build-complete-90of90-backup-20260420
.claude/generated_features.json.pre-hardening-backup-20260420
.claude/spec.md
CLAUDE.local.md
