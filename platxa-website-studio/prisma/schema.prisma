// Platxa Website Studio - Database Schema
// PostgreSQL database for users, projects, and deployments

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String    // bcrypt hashed
  avatar        String?
  role          UserRole  @default(USER)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  projects      Project[]
  deployments   Deployment[]
  sessions      Session[]
  apiKeys       ApiKey[]

  // Credit & Billing relations
  creditAccount   CreditAccount?
  subscriptions   Subscription[]
  creditTransactions CreditTransaction[]

  @@index([email])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ApiKey {
  id        String   @id @default(cuid())
  name      String
  key       String   @unique
  userId    String
  lastUsed  DateTime?
  expiresAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([key])
}

enum UserRole {
  USER
  ADMIN
  DEVELOPER
}

// ============================================
// PROJECTS
// ============================================

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  industry    String?       // restaurant, tech, legal, etc.
  colorPalette Json?        // { primary, secondary, accent }
  settings    Json?         // Additional project settings
  status      ProjectStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Owner
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relations
  files       ProjectFile[]
  deployments Deployment[]
  snapshots   ProjectSnapshot[]

  @@index([userId])
  @@index([status])
}

model ProjectFile {
  id        String   @id @default(cuid())
  path      String   // e.g., "theme_generated/views/homepage.xml"
  name      String   // e.g., "homepage.xml"
  content   String   @db.Text
  language  String   // xml, scss, python, etc.
  isGenerated Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, path])
  @@index([projectId])
}

model ProjectSnapshot {
  id          String   @id @default(cuid())
  name        String   // e.g., "Before deployment v1.2"
  description String?
  files       Json     // Snapshot of all file contents
  createdAt   DateTime @default(now())

  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Link to deployment if this was a pre-deployment snapshot
  deploymentId String?  @unique
  deployment   Deployment? @relation("PreDeploymentSnapshot", fields: [deploymentId], references: [id])

  @@index([projectId])
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ARCHIVED
  DELETED
}

// ============================================
// DEPLOYMENTS & ROLLBACK
// ============================================

model Deployment {
  id              String           @id @default(cuid())
  version         String           // e.g., "1.0.0", "1.0.1"
  status          DeploymentStatus @default(PENDING)

  // Odoo target
  odooUrl         String           // e.g., "https://mycompany.odoo.com"
  odooDatabase    String
  moduleName      String           // e.g., "theme_generated"

  // Deployment details
  filesDeployed   Json             // List of files deployed
  manifestContent String?          @db.Text

  // Verification
  verifiedAt      DateTime?
  verificationLog String?          @db.Text

  // Error handling
  errorMessage    String?          @db.Text
  errorCode       String?

  // Timing
  startedAt       DateTime         @default(now())
  completedAt     DateTime?

  // Relations
  projectId       String
  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Pre-deployment snapshot for rollback
  snapshot        ProjectSnapshot? @relation("PreDeploymentSnapshot")

  // Rollback reference
  rolledBackFrom  Deployment?      @relation("RollbackChain", fields: [rolledBackFromId], references: [id])
  rolledBackFromId String?
  rollbackTo      Deployment[]     @relation("RollbackChain")

  @@index([projectId])
  @@index([userId])
  @@index([status])
}

enum DeploymentStatus {
  PENDING
  UPLOADING
  INSTALLING
  VERIFYING
  SUCCESS
  FAILED
  ROLLED_BACK
}

// ============================================
// RATE LIMITING & ANALYTICS
// ============================================

model RateLimitEntry {
  id        String   @id @default(cuid())
  key       String   // userId or IP address
  endpoint  String   // e.g., "/api/chat"
  count     Int      @default(1)
  windowStart DateTime @default(now())

  @@unique([key, endpoint])
  @@index([key])
  @@index([windowStart])
}

model UsageLog {
  id          String   @id @default(cuid())
  userId      String?
  endpoint    String
  method      String
  statusCode  Int
  duration    Int      // milliseconds
  tokensUsed  Int?     // For AI endpoints
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([endpoint])
  @@index([createdAt])
}

// ============================================
// CREDIT SYSTEM & BILLING
// ============================================

model CreditAccount {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Credit balances
  balance               Int      @default(100)  // Current available credits
  lifetimeCredits       Int      @default(100)  // Total credits ever received
  usedThisMonth         Int      @default(0)    // Credits used in current billing cycle

  // Plan info (cached from active subscription)
  plan                  PlanType @default(FREE)
  monthlyAllowance      Int      @default(100)  // Credits included in plan per month

  // Billing cycle
  billingCycleStart     DateTime @default(now())
  billingCycleEnd       DateTime?

  // Timestamps
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([userId])
  @@index([plan])
}

model CreditTransaction {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Transaction details
  amount      Int               // Positive for credits added, negative for used
  type        TransactionType

  // Context
  projectId   String?           // Which project this relates to
  description String            // Human-readable description
  metadata    Json?             // Additional context (model used, tokens, etc.)

  // Balance tracking
  balanceBefore Int             // Balance before this transaction
  balanceAfter  Int             // Balance after this transaction

  createdAt   DateTime          @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@index([projectId])
}

model Subscription {
  id                String             @id @default(cuid())
  userId            String
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Plan details
  plan              PlanType           @default(FREE)
  status            SubscriptionStatus @default(ACTIVE)

  // Billing
  priceMonthly      Int                @default(0)   // Price in cents
  currency          String             @default("USD")

  // Period
  currentPeriodStart DateTime          @default(now())
  currentPeriodEnd   DateTime?
  cancelledAt        DateTime?
  cancelAtPeriodEnd  Boolean           @default(false)

  // External payment provider reference
  stripeSubscriptionId String?         @unique
  stripeCustomerId     String?

  // Trial
  trialStart         DateTime?
  trialEnd           DateTime?

  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([userId])
  @@index([status])
  @@index([stripeSubscriptionId])
}

model PricingPlan {
  id                String   @id @default(cuid())
  name              String   @unique  // free, starter, team, business, enterprise
  displayName       String            // "Free", "Starter", etc.

  // Pricing
  priceMonthly      Int      @default(0)   // Price in cents
  priceYearly       Int      @default(0)   // Annual price in cents
  currency          String   @default("USD")

  // Credits
  monthlyCredits    Int      @default(100)

  // Limits
  maxProjects       Int      @default(3)
  maxDeployments    Int      @default(5)
  maxTeamMembers    Int      @default(1)
  storageGb         Int      @default(1)
  apiCallsPerDay    Int      @default(100)

  // Features
  features          Json     // Array of feature flags

  // Display
  isRecommended     Boolean  @default(false)
  isActive          Boolean  @default(true)
  sortOrder         Int      @default(0)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([name])
  @@index([isActive])
}

enum PlanType {
  FREE
  STARTER
  TEAM
  BUSINESS
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  TRIALING
  PAUSED
  INCOMPLETE
}

enum TransactionType {
  // Credit additions
  SIGNUP_BONUS         // Initial free credits
  PLAN_ALLOWANCE       // Monthly plan credits
  PURCHASE             // Bought credits
  REFERRAL_BONUS       // Referral reward
  PROMO_CODE           // Promotional credits
  ADMIN_ADJUSTMENT     // Manual admin adjustment
  REFUND               // Credit refund

  // Credit usage
  THEME_GENERATION     // AI theme generation
  THEME_ITERATION      // AI iteration/refinement
  EXPORT               // Theme export
  DEPLOYMENT           // Deployment to Odoo
  API_CALL             // API usage
}

// ============================================
// GITHUB INTEGRATION
// ============================================

model GitHubConnection {
  id            String   @id @default(cuid())
  userId        String

  // GitHub OAuth tokens
  accessToken   String   // Encrypted access token
  tokenType     String   @default("bearer")
  scope         String   // Comma-separated scopes

  // GitHub user info
  githubId      Int      @unique
  githubLogin   String
  githubEmail   String?
  githubAvatar  String?

  // Token metadata
  obtainedAt    DateTime @default(now())
  expiresAt     DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId])
  @@index([githubId])
  @@index([githubLogin])
}

model GitHubRepository {
  id            String   @id @default(cuid())
  projectId     String   @unique

  // Repository info
  owner         String
  repo          String
  branch        String   @default("main")
  fullName      String   // owner/repo
  isPrivate     Boolean  @default(false)

  // Sync state
  lastSyncAt    DateTime?
  lastCommitSha String?
  syncStatus    GitHubSyncStatus @default(IDLE)

  // Webhook
  webhookId     Int?
  webhookSecret String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([owner, repo, branch])
  @@index([projectId])
  @@index([syncStatus])
}

enum GitHubSyncStatus {
  IDLE
  SYNCING
  CONFLICT
  ERROR
  UP_TO_DATE
}
