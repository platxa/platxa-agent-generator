# Database Configuration (REQUIRED)
# PostgreSQL connection string
# Local: postgresql://user:password@localhost:5432/platxa
# Docker: postgresql://platxa:platxa@db:5432/platxa
DATABASE_URL=postgresql://platxa:platxa@localhost:5432/platxa

# NextAuth.js Configuration (REQUIRED)
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# Anthropic API Key for Claude AI (optional if using Ollama)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Sidecar URL (platxa-editor-sync)
NEXT_PUBLIC_SIDECAR_URL=http://localhost:3001

# Odoo Instance Configuration
NEXT_PUBLIC_ODOO_URL=http://localhost:8069
ODOO_DATABASE=odoo
ODOO_USERNAME=admin
# Odoo API key for deployments (get from Odoo Settings > Users > API Keys)
ODOO_API_KEY=

# Optional: Enable debug mode
NEXT_PUBLIC_DEBUG=false

# Sentry Error Monitoring (optional)
# Get your DSN from https://sentry.io
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=your-org
SENTRY_PROJECT=platxa-website-studio

# Real-time Collaboration (optional)
# WebSocket server for multi-user collaboration
# Run: npx y-websocket
NEXT_PUBLIC_COLLAB_SERVER_URL=ws://localhost:1234
