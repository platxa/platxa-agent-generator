# =============================================================================
# Docker Ignore
# =============================================================================
# Files and directories to exclude from Docker build context

# Dependencies
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Next.js
.next
out

# Testing
coverage
.nyc_output
e2e/test-results
playwright-report

# IDE
.idea
.vscode
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Environment files (use docker-compose env)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Git
.git
.gitignore

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore

# Documentation
*.md
!README.md

# Misc
*.log
.eslintcache
.turbo
